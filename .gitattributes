# Auto detect text files and perform LF normalization
* text=auto

# Java source files
*.java text diff=java
*.gradle text diff=java
*.kt text diff=java
*.kts text diff=java

# XML files
*.xml text
*.xsd text
*.xsl text
*.xslt text

# Property files
*.properties text

# Markdown files
*.md text diff=markdown

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Batch scripts (Windows)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# SQL files
*.sql text

# Web files
*.html text diff=html
*.css text diff=css
*.js text
*.json text

# Documentation
*.txt text
*.adoc text
*.textile text
*.mustache text
*.csv text
*.tab text
*.tsv text

# Binary files
*.jar binary
*.class binary
*.war binary
*.ear binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary

# Image files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary

# Font files
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary
